{
	"rootDir": "../../",
	"resetMocks": true,
	"restoreMocks": true,
	"maxWorkers": "50%",
	"setupFiles": [
		"<rootDir>/test/integration/setup-env.ts"
	],
	"transform": {
	  "^.+\\.(ts)$": [
		"ts-jest",
		{
		  "tsconfig": "<rootDir>/test/tsconfig.test.json"
		}
	  ]
	},
	"testMatch": [
		"<rootDir>/test/integration/**/*.test.(ts|js)"
	],
	"collectCoverage": false,
	"testTimeout": 60000
  }
